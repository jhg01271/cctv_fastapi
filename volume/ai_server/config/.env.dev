# 애플리케이션
APP_NAME=FASTAPI Framework
APP_ENV=dev
DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000

# 언어
DEFAULT_LANGUAGE=ko

# 데이터 베이스
DB_HOST=192.168.3.37
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=!Gns@jeonjin
DB_ECHO=true
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# 로그레벨 설정 DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

HTTP_TIMEOUT=10.0
STREAM_GATEWAY_URL=http://stream_gateway:8010

# MediaMTX (미디어 서버)
MEDIA_SERVER_HOST=192.168.3.42
MEDIA_SERVER_RTSP_PORT=8554
MEDIA_SERVER_WEBRTC_PORT=8889
MEDIA_SERVER_API_PORT=9997

# AI 모델 경로 (절대경로 또는 main/ 기준 상대경로)
MODEL_SAFETY_PT=./model/helmet_yolo26m.pt
MODEL_POSE_CROP_PT=./model/falling_crop_0518_0917.pt
MODEL_POSE_FULL_PT=./model/falling_0430_0911.pt
MODEL_PROGRESS_PT=./model/BWTS_model.pt

# AI 처리 설정
AI_POSE_MODE=crop
AI_FRAME_SKIP=6
AI_FRAME_QUEUE_SIZE=2
AI_READER_FIRST_FRAME_TIMEOUT_SEC=20
AI_READER_INPUT=source
AI_CONFIDENCE_THRESHOLD=0.3
AI_STARTUP_DELAY=45
AI_WORKER_STARTUP_GRACE_SEC=120
AI_POSE_MAX_CROPS=1
AI_EVENT_COOLDOWN_SEC=600
AI_COLLAPSE_SUSTAIN_SEC=15.0
AI_E003_BUFFER_MAX=300
AI_E004_PREDICT_SEC=2.0
AI_E004_PERSON_SUSTAIN_SEC=3.0
AI_E004_HISTORY_MAXLEN=10

# 이미지 저장 경로
EVENT_IMAGE_DIR=./img_save/event_images
PROGRESS_RESULT_DIR=./img_save/progress_results

# 공정률 처리 주기 (초)
PROGRESS_CYCLE_SEC=60
